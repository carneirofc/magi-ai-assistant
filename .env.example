# ============================================================================
# App config (read by core/config.py)
# ============================================================================

# LiteLLM proxy — the one gateway to every model backend (see litellm.config.yaml)
LITELLM_BASE_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-litellm-dev-key

# Models (ids are litellm proxy model_names)
LEAD_MODEL_ID=qwen3.5-9b-uncensored
LEAD_NUM_CTX=131072            # 128k context window for the lead/router brain
MEMBER_MODEL_ID=qwen3.5-9b-uncensored
MEMBER_NUM_CTX=32768
MODEL_TEMPERATURE=0.7

# Agent behavior — default prompt lives in prompts/system.md (edit that file).
# Uncomment to override the file for this deployment only:
# SYSTEM_PROMPT=You are a helpful personal AI assistant.

# Persistence (sessions + long-term user memories)
# DB_FILE=data/chatbot.db

# Deliberate memory — markdown files the model reads/writes on purpose (core/memory)
# MEMORY_DIR=data/memory
# SHORT_TERM_MAX=20            # recent turns kept per session
# PERSONA_SEED=...            # base persona lives in prompts/team/lead.md; set this only to pre-seed the memory layer

# Team robustness
# TOOL_CALL_LIMIT=12           # max tool/member calls per run (bounds delegation loops)

# Context-size monitoring (logged each run; never truncates)
# CTX_WARN_RATIO=0.75          # warn when assembled context exceeds this fraction of LEAD_NUM_CTX

# Auto-summarize on evict — fold rolled-off turns into an episode instead of dropping
# SUMMARIZE_ON_EVICT=false
# SUMMARIZE_EVERY=10           # evicted turns batched per summary call

# Semantic memory search (needs Qdrant + an embedding model; `uv sync --extra semantic`)
# SEMANTIC_MEMORY=false
# EMBEDDING_MODEL_ID=nomic-embed-text
# SEMANTIC_TOP_K=5
# QDRANT_API_BASE / QDRANT_API_KEY are set below (shared with the proxy)

# Seanime media server — only needed when the server has a password set
# (sent as X-Seanime-Token; base URL is code-first in core/config.py)
# SEANIME_TOKEN=

# Discord bot
DISCORD_BOT_TOKEN=

# Admin service (channels/admin + web/ BFF) — operator-only management UI, ADR 0002.
# Brought up with `docker compose -f docker-compose.app.yaml --profile admin up`.
# ADMIN_AUTH_TOKEN gates the Python admin-api and is the bearer the web BFF presents
# (same value both sides). ADMIN_PASSWORD unlocks the UI; SESSION_SECRET signs the
# operator's httpOnly session cookie. All three are server-side only.
ADMIN_AUTH_TOKEN=
ADMIN_PASSWORD=
SESSION_SECRET=

# ============================================================================
# Consumed by the LiteLLM proxy process (see litellm.config.yaml).
# core/config.py also reads OLLAMA_HOST for the direct-Ollama builder.
# ============================================================================

# Backends
OLLAMA_HOST=http://localhost:11434
QWEN_API_BASE=http://localhost:11434
QWEN_API_KEY=
DATABRICKS_TOKEN=dapi...
DATABRICKS_API_BASE=https://<workspace>.azuredatabricks.net/serving-endpoints

# Proxy infra
DATABASE_URL=postgresql://litellm:litellm@localhost:5432/litellm
LITELLM_PROXY_BASE_URL=http://localhost:4000
QDRANT_API_BASE=http://localhost:6333
QDRANT_API_KEY=

# MinIO (S3-compatible object storage for LiteLLM request logs)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=litellm-logs

# ============================================================================
# Object storage — the chatbot's durable file/image archive (core/storage).
# Only the credentials are secrets; bucket/region/endpoint are set in code via
# configure(). Off unless s3_enabled=True in the entrypoint. The defaults below
# match the bundled RustFS (docker compose up -d rustfs rustfs-init). Also read
# by docker-compose.yaml to seed RustFS creds + the chatbot-memory bucket.
# ============================================================================
S3_ACCESS_KEY_ID=rustfsadmin
S3_SECRET_ACCESS_KEY=rustfsadmin
# S3_BUCKET=chatbot-memory   # (compose-only) bucket rustfs-init creates
