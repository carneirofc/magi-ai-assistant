# Model selection (swap provider without code changes)
MODEL_PROVIDER=anthropic            # anthropic | ollama
MODEL_ID=claude-sonnet-4-5-20250929
ANTHROPIC_API_KEY=sk-ant-...
# OLLAMA_HOST=http://localhost:11434

# Agent behavior — default prompt lives in prompts/system.md (edit that file).
# Uncomment to override the file for this deployment only:
# SYSTEM_PROMPT=You are a helpful personal AI assistant.

# OpenAI-compatible API server (OpenWebUI connects here)
API_TOKEN=change-me
HOST=0.0.0.0
PORT=8000

# Discord bot
DISCORD_BOT_TOKEN=

# LiteLLM proxy
LITELLM_MASTER_KEY=sk-litellm-dev-key
# LITELLM_MODEL_NAME=claude-sonnet-4-5-20250929
# LITELLM_PROVIDER_MODEL=anthropic/claude-sonnet-4-5-20250929

# MinIO (S3-compatible object storage for LiteLLM request logs)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=litellm-logs
