# MAGI admin web (BFF) — server-side only. None of these reach the browser.
#
# The Python admin-api base URL. In docker-compose this is the service name on the
# compose network; for local dev it's the host/port main_admin.py binds.
ADMIN_API_URL=http://127.0.0.1:8100

# Bearer token the BFF presents to the admin-api. MUST equal the admin-api's
# ADMIN_AUTH_TOKEN. Never shipped to the browser.
ADMIN_AUTH_TOKEN=change-me

# The single operator password. Login compares against this, then sets a signed
# httpOnly session cookie.
ADMIN_PASSWORD=change-me

# Secret used to sign the session cookie (HMAC). Any long random string.
SESSION_SECRET=change-me-to-a-long-random-string

# Build-time only (NOT read at runtime): GitHub Personal Access Token with the
# read:packages scope, used by `npm install` to fetch @carneirofc/ui from GitHub
# Packages. See README "Installing @carneirofc/ui". Export it in your shell before
# installing/building; for Docker pass it as a build secret (id=node_auth_token).
# NODE_AUTH_TOKEN=ghp_xxx
