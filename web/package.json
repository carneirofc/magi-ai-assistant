{
  "name": "magi-admin-web",
  "version": "0.1.0",
  "private": true,
  "description": "Operator admin UI + BFF for MAGI memory & knowledge (ADR 0002). Reference app for the @carneirofc/magi-web frontend library.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "gen:api": "npm run gen:api -w @carneirofc/magi-web"
  },
  "dependencies": {
    "@carneirofc/magi-web": "file:./packages/magi-web",
    "@carneirofc/ui": "file:../../deedlit.dev/deedlit.dev.ui",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "overrides": {
    "postcss": ">=8.5.10",
    "js-yaml": ">=4.2.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
