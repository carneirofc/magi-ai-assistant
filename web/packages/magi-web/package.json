{
  "name": "@carneirofc/magi-web",
  "version": "0.6.0",
  "description": "MAGI frontend library — presentational React components and the SSE chat runtime for building magi-engine admin/chat UIs. Consumed from source via Next.js transpilePackages.",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": false,
  "files": [
    "src",
    "scripts",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carneirofc/magi-ai-assistant.git",
    "directory": "web/packages/magi-web"
  },
  "exports": {
    "./package.json": "./package.json",
    "./components/*": "./src/components/*.tsx",
    "./lib/chat-mood": "./src/lib/chat-mood.tsx",
    "./lib/chat-voice": "./src/lib/chat-voice.tsx",
    "./lib/*": "./src/lib/*.ts",
    "./slices/core": "./src/slices/core.ts",
    "./slices/shell": "./src/slices/shell.tsx",
    "./slices/chat": "./src/slices/chat/index.ts",
    "./slices/chat/types": "./src/slices/chat/types.ts",
    "./slices/chat/hooks": "./src/slices/chat/hooks.ts",
    "./slices/chat/components": "./src/slices/chat/components.ts",
    "./slices/chat/screens": "./src/slices/chat/screens.ts",
    "./slices/chat/routes": "./src/slices/chat/routes.ts",
    "./slices/companion": "./src/slices/companion/index.ts",
    "./slices/companion/components": "./src/slices/companion/components.ts",
    "./slices/knowledge": "./src/slices/knowledge/index.ts",
    "./slices/knowledge/types": "./src/slices/knowledge/types.ts",
    "./slices/knowledge/hooks": "./src/slices/knowledge/hooks.ts",
    "./slices/knowledge/components": "./src/slices/knowledge/components.ts",
    "./slices/knowledge/screens": "./src/slices/knowledge/screens.ts",
    "./routes/*": "./src/routes/*.ts",
    "./pages/*": "./src/pages/*.tsx",
    "./middleware": "./src/middleware.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "gen:api": "node scripts/gen-api.mjs"
  },
  "peerDependencies": {
    "@carneirofc/ui": ">=0.2.0",
    "next": ">=15",
    "react": ">=19",
    "react-dom": ">=19"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.24",
    "@assistant-ui/react-markdown": "^0.14.5",
    "@aws-sdk/client-s3": "^3.1079.0",
    "@radix-ui/react-tooltip": "^1.2.11",
    "beautiful-mermaid": "^1.1.3",
    "clsx": "^2.1.1",
    "react-markdown": "^9.0.0",
    "react-shiki": "^0.10.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "openapi-typescript": "^7.4.0",
    "typescript": "^5.7.0"
  }
}
